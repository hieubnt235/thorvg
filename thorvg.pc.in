prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include/thorvg-@PROJECT_VERSION_MAJOR@

Name: libthorvg
Description: A Thor library for rendering vector graphics
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lthorvg-@PROJECT_VERSION_MAJOR@
Cflags: -I${includedir}